FROM node:20-alpine
WORKDIR /app

# Install dependencies first (cached layer)
COPY package*.json ./
# Install all deps including devDependencies (needed for @nestjs/cli)
RUN npm install

# Copy project files (source is overridden by volume mount in docker-compose)
COPY . .

# nest start --watch compiles src/ → dist/ and restarts on changes
CMD ["npm", "run", "start:dev"]
