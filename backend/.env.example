# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ton-service
DATABASE_USER=romashka
DATABASE_PASSWORD=7851

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# TON Blockchain
TON_NETWORK=testnet
TON_API_KEY=
TON_ADMIN_WALLET_MNEMONIC=

# Email
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=test@example.com
MAIL_PASSWORD=password
MAIL_FROM=Marketplace <noreply@marketplace.com>

# Security
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_TTL=900
AUTH_RATE_LIMIT_MAX=5
CSRF_ENABLED=false

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
MAX_FILES=10
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
